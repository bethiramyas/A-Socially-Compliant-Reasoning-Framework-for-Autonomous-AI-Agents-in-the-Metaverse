{
  "dataset_info": {
    "name": "Synthetic Conflict Mediation Interactions",
    "scenario": "mediation",
    "description": "Simulated multi-party conflict mediation sessions where an AI mediator agent works to de-escalate disputes between two or more user avatars in a Unity3D virtual environment. Sessions are annotated with per-turn emotion labels, norm compliance scores, de-escalation actions, and ontology-grounded reasoning traces. This is the most socially complex scenario in the framework, requiring simultaneous emotional sensitivity, fairness, and structured reasoning.",
    "num_sessions": 50,
    "num_turns_total": 712,
    "roles": ["mediator_agent", "party_A", "party_B"],
    "emotion_classes": ["neutral", "angry", "frustrated", "anxious", "calm", "satisfied", "defensive"],
    "compliance_range": [0.0, 1.0],
    "annotation_schema": {
      "session_id": "Unique session identifier",
      "scenario": "Scenario type",
      "context": "Dispute topic, parties involved, and environment metadata",
      "turns": "List of interaction turns",
      "turn.id": "Turn index within session",
      "turn.role": "Speaker role: mediator_agent, party_A, or party_B",
      "turn.text": "Utterance text",
      "turn.emotion": "Detected or ground-truth emotion label",
      "turn.emotion_confidence": "Confidence score of emotion label [0,1]",
      "turn.compliance_score": "Norm compliance score NC_t in [0,1] (Eq. 9 in paper). Null for non-agent turns.",
      "turn.practice_active": "Active social practice from SPT library",
      "turn.ontology_context": "Active ontology concepts guiding mediator agent reasoning",
      "turn.agent_action": "Symbolic action type taken by mediator agent",
      "turn.escalation_level": "Current conflict intensity on a 1-5 scale (1=calm, 5=severe)",
      "session.dispute_type": "Category of dispute",
      "session.outcome": "Session-level outcome label",
      "session.avg_compliance": "Mean NC score across session",
      "session.avg_emotion_alignment": "Mean emotion alignment score EA across session",
      "session.user_trust": "Post-session average user trust rating on 5-point scale",
      "session.de_escalation_delta": "Change in escalation level from session start to end (negative = de-escalated)"
    }
  },
  "sessions": [
    {
      "session_id": "MED_001",
      "scenario": "mediation",
      "context": {
        "dispute_type": "Team project disagreement",
        "party_A": "Student — project lead",
        "party_B": "Student — team member",
        "environment": "VR Mediation Room — SR University",
        "session_duration_turns": 16,
        "initial_escalation_level": 4
      },
      "turns": [
        {
          "id": 1,
          "role": "mediator_agent",
          "text": "Thank you both for agreeing to talk today. I want this to be a space where each of you can speak freely and feel heard. No one will be judged here. Can we start by each sharing, briefly, what is troubling you?",
          "emotion": "neutral",
          "emotion_confidence": 0.95,
          "compliance_score": 0.94,
          "practice_active": "opening_safe_space",
          "ontology_context": ["Mediation:NeutralOpening", "Norm:SafeSpace", "Role:Mediator"],
          "agent_action": "establish_ground_rules",
          "escalation_level": 4
        },
        {
          "id": 2,
          "role": "party_A",
          "text": "She never submits her sections on time and the whole group ends up suffering because of it.",
          "emotion": "angry",
          "emotion_confidence": 0.88,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 4
        },
        {
          "id": 3,
          "role": "party_B",
          "text": "That is not fair! I had a family emergency and I told you about it. You just do not care about anyone's personal situation.",
          "emotion": "defensive",
          "emotion_confidence": 0.86,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 4
        },
        {
          "id": 4,
          "role": "mediator_agent",
          "text": "I can hear that both of you are carrying real frustration right now, and that makes sense. Before we respond to each other, let us make sure we each feel understood. Can I reflect back what I heard? Party A, you felt the delays affected the whole team. Party B, you experienced a personal emergency and felt that was not acknowledged. Does that capture both sides fairly?",
          "emotion": "neutral",
          "emotion_confidence": 0.94,
          "compliance_score": 0.96,
          "practice_active": "active_reflective_listening",
          "ontology_context": ["Mediation:Paraphrasing", "Norm:Fairness", "Norm:Empathy", "Emotion:Angry", "Emotion:Defensive"],
          "agent_action": "reflect_and_validate_both",
          "escalation_level": 3
        },
        {
          "id": 5,
          "role": "party_A",
          "text": "Yes, that is what I mean. But she could have just told us sooner.",
          "emotion": "frustrated",
          "emotion_confidence": 0.85,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 3
        },
        {
          "id": 6,
          "role": "party_B",
          "text": "I did tell you. You just did not listen. You only care about the deadline.",
          "emotion": "frustrated",
          "emotion_confidence": 0.84,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 3
        },
        {
          "id": 7,
          "role": "mediator_agent",
          "text": "There seems to be a difference in how the communication was received. Party B, when exactly did you communicate the emergency, and through which channel? This is not about blame — I want to understand the gap so we can prevent it in future.",
          "emotion": "neutral",
          "emotion_confidence": 0.93,
          "compliance_score": 0.93,
          "practice_active": "fact_clarification",
          "ontology_context": ["Mediation:FactFinding", "Norm:Neutrality", "Norm:NoBlame", "Role:Mediator"],
          "agent_action": "clarify_facts_neutrally",
          "escalation_level": 3
        },
        {
          "id": 8,
          "role": "party_B",
          "text": "I sent a message on the group chat two days before the deadline. I still have it.",
          "emotion": "anxious",
          "emotion_confidence": 0.82,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 2
        },
        {
          "id": 9,
          "role": "party_A",
          "text": "I think I missed that message honestly. We had a lot of messages that week.",
          "emotion": "neutral",
          "emotion_confidence": 0.80,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 2
        },
        {
          "id": 10,
          "role": "mediator_agent",
          "text": "Thank you for that honesty. It sounds like the message was sent but got lost in volume — that is a communication system problem, not a personal failure from either of you. Can we agree on that together?",
          "emotion": "neutral",
          "emotion_confidence": 0.94,
          "compliance_score": 0.95,
          "practice_active": "reframe_as_systemic",
          "ontology_context": ["Mediation:Reframing", "Norm:SharedResponsibility", "Norm:NonJudgement"],
          "agent_action": "reframe_and_seek_agreement",
          "escalation_level": 2
        },
        {
          "id": 11,
          "role": "party_A",
          "text": "I suppose that is fair. I should have checked the chat more carefully.",
          "emotion": "calm",
          "emotion_confidence": 0.87,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 2
        },
        {
          "id": 12,
          "role": "party_B",
          "text": "And I could have followed up with a direct message as well.",
          "emotion": "calm",
          "emotion_confidence": 0.88,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 1
        },
        {
          "id": 13,
          "role": "mediator_agent",
          "text": "That mutual recognition is really meaningful. You are both showing real maturity here. Can we now agree on a simple team protocol going forward — for instance, critical updates go both to the group chat and a direct message to the lead?",
          "emotion": "neutral",
          "emotion_confidence": 0.95,
          "compliance_score": 0.96,
          "practice_active": "agreement_building",
          "ontology_context": ["Mediation:ActionAgreement", "Norm:Collaboration", "Norm:Respect"],
          "agent_action": "build_forward_agreement",
          "escalation_level": 1
        },
        {
          "id": 14,
          "role": "party_A",
          "text": "Yes, that would have prevented all of this.",
          "emotion": "calm",
          "emotion_confidence": 0.90,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 1
        },
        {
          "id": 15,
          "role": "party_B",
          "text": "Agreed. And I am sorry for the stress it caused the team.",
          "emotion": "calm",
          "emotion_confidence": 0.91,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 1
        },
        {
          "id": 16,
          "role": "mediator_agent",
          "text": "Thank you both. What you just did — listening, acknowledging, and agreeing on a path forward — is genuinely difficult and you handled it with care. I wish you both the best with the rest of the project.",
          "emotion": "satisfied",
          "emotion_confidence": 0.96,
          "compliance_score": 0.97,
          "practice_active": "closing_with_affirmation",
          "ontology_context": ["Mediation:PositiveClosure", "Norm:Affirmation", "Role:Mediator"],
          "agent_action": "close_with_affirmation",
          "escalation_level": 1
        }
      ],
      "dispute_type": "team_project_disagreement",
      "session_outcome": "resolved",
      "avg_compliance": 0.952,
      "avg_emotion_alignment": 0.91,
      "user_trust": 4.7,
      "de_escalation_delta": -3
    },
    {
      "session_id": "MED_002",
      "scenario": "mediation",
      "context": {
        "dispute_type": "Workplace task allocation complaint",
        "party_A": "Junior employee",
        "party_B": "Senior colleague",
        "environment": "VR Office — Mediation Suite",
        "session_duration_turns": 14,
        "initial_escalation_level": 3
      },
      "turns": [
        {
          "id": 1,
          "role": "mediator_agent",
          "text": "I am here to help both of you work through a difficult situation constructively. Everything discussed stays in this room. Would you like to begin, starting with the concern that was raised?",
          "emotion": "neutral",
          "emotion_confidence": 0.94,
          "compliance_score": 0.93,
          "practice_active": "confidential_opening",
          "ontology_context": ["Mediation:Confidentiality", "Norm:SafeSpace", "Role:Mediator"],
          "agent_action": "establish_confidentiality",
          "escalation_level": 3
        },
        {
          "id": 2,
          "role": "party_A",
          "text": "I keep being assigned the repetitive tasks while my colleague gets all the interesting project work. It feels deliberate.",
          "emotion": "frustrated",
          "emotion_confidence": 0.85,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 3
        },
        {
          "id": 3,
          "role": "party_B",
          "text": "That is not how it works. Tasks are assigned based on experience. I have been here longer.",
          "emotion": "defensive",
          "emotion_confidence": 0.83,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 3
        },
        {
          "id": 4,
          "role": "mediator_agent",
          "text": "Both of you have raised valid points. Party A, feeling stuck on routine tasks can be demoralising. Party B, experience-based allocation is a real consideration. I do not think either of you is wrong — but there may be a gap in how the reasoning is being communicated. Can we explore that?",
          "emotion": "neutral",
          "emotion_confidence": 0.93,
          "compliance_score": 0.95,
          "practice_active": "dual_validation",
          "ontology_context": ["Mediation:DualValidation", "Norm:Fairness", "Norm:Neutrality"],
          "agent_action": "validate_both_perspectives",
          "escalation_level": 2
        },
        {
          "id": 5,
          "role": "party_A",
          "text": "I just want to know the criteria. No one has explained what I need to do to get more complex work.",
          "emotion": "anxious",
          "emotion_confidence": 0.84,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 2
        },
        {
          "id": 6,
          "role": "party_B",
          "text": "I assumed it was understood. You need to show reliability on the basics first.",
          "emotion": "neutral",
          "emotion_confidence": 0.82,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 2
        },
        {
          "id": 7,
          "role": "mediator_agent",
          "text": "That is a meaningful clarification. It sounds like the expectation exists but was not made explicit. Party A, does hearing that help at all — even if the criteria feels vague?",
          "emotion": "neutral",
          "emotion_confidence": 0.92,
          "compliance_score": 0.92,
          "practice_active": "expectation_surfacing",
          "ontology_context": ["Mediation:ExpectationClarification", "Norm:Transparency", "Role:Mediator"],
          "agent_action": "surface_implicit_expectations",
          "escalation_level": 2
        },
        {
          "id": 8,
          "role": "party_A",
          "text": "A little. I just wish it had been said clearly from the start.",
          "emotion": "calm",
          "emotion_confidence": 0.86,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 2
        },
        {
          "id": 9,
          "role": "party_B",
          "text": "Fair point. I should have made that clearer. I will be more explicit going forward.",
          "emotion": "calm",
          "emotion_confidence": 0.87,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 1
        },
        {
          "id": 10,
          "role": "mediator_agent",
          "text": "That commitment means a lot. Can we go one step further and agree on a concrete milestone — perhaps one higher-complexity task assigned to Party A in the next cycle with the criteria explained upfront?",
          "emotion": "neutral",
          "emotion_confidence": 0.93,
          "compliance_score": 0.94,
          "practice_active": "concrete_milestone_agreement",
          "ontology_context": ["Mediation:ActionPlan", "Norm:Commitment", "Norm:Fairness"],
          "agent_action": "propose_concrete_milestone",
          "escalation_level": 1
        },
        {
          "id": 11,
          "role": "party_B",
          "text": "Yes. I can do that next sprint.",
          "emotion": "calm",
          "emotion_confidence": 0.89,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 1
        },
        {
          "id": 12,
          "role": "party_A",
          "text": "That would be great. Thank you.",
          "emotion": "satisfied",
          "emotion_confidence": 0.92,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 1
        },
        {
          "id": 13,
          "role": "mediator_agent",
          "text": "Excellent. You have turned what felt like unfairness into a shared plan. That took real willingness from both of you. I will note this agreement so it can be reviewed if needed.",
          "emotion": "satisfied",
          "emotion_confidence": 0.95,
          "compliance_score": 0.95,
          "practice_active": "closing_with_documentation",
          "ontology_context": ["Mediation:PositiveClosure", "Norm:Accountability", "Role:Mediator"],
          "agent_action": "close_and_document",
          "escalation_level": 1
        }
      ],
      "dispute_type": "workplace_task_allocation",
      "session_outcome": "resolved",
      "avg_compliance": 0.938,
      "avg_emotion_alignment": 0.90,
      "user_trust": 4.5,
      "de_escalation_delta": -2
    },
    {
      "session_id": "MED_003",
      "scenario": "mediation",
      "context": {
        "dispute_type": "Neighbour noise complaint",
        "party_A": "Resident — complainant",
        "party_B": "Resident — respondent",
        "environment": "VR Community Centre — Mediation Room",
        "session_duration_turns": 14,
        "initial_escalation_level": 4
      },
      "turns": [
        {
          "id": 1,
          "role": "mediator_agent",
          "text": "Thank you for coming. I know it takes courage to sit in the same room when feelings are running high. I am here to make sure both of you are heard equally. Shall we begin?",
          "emotion": "neutral",
          "emotion_confidence": 0.95,
          "compliance_score": 0.94,
          "practice_active": "courage_acknowledgement_opening",
          "ontology_context": ["Mediation:NeutralOpening", "Norm:Courage", "Norm:Equality", "Role:Mediator"],
          "agent_action": "acknowledge_effort_and_open",
          "escalation_level": 4
        },
        {
          "id": 2,
          "role": "party_A",
          "text": "The music from next door is loud every night until 2am. I have not been sleeping properly for three weeks. I am exhausted.",
          "emotion": "frustrated",
          "emotion_confidence": 0.87,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 4
        },
        {
          "id": 3,
          "role": "party_B",
          "text": "It is not every night and it is never past midnight. I work from home and I need to unwind sometimes.",
          "emotion": "defensive",
          "emotion_confidence": 0.84,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 4
        },
        {
          "id": 4,
          "role": "mediator_agent",
          "text": "There is clearly a difference in how the situation is being experienced, and that is very common in noise disputes. I am not here to decide who is right. What I want us to find is a solution that lets both of you live comfortably. Can we each share what a good outcome would look like to them personally?",
          "emotion": "neutral",
          "emotion_confidence": 0.94,
          "compliance_score": 0.95,
          "practice_active": "needs_elicitation",
          "ontology_context": ["Mediation:NeedsElicitation", "Norm:Neutrality", "Norm:MutualBenefit"],
          "agent_action": "reframe_toward_needs",
          "escalation_level": 3
        },
        {
          "id": 5,
          "role": "party_A",
          "text": "I just want quiet after 11pm so I can sleep and function the next day.",
          "emotion": "anxious",
          "emotion_confidence": 0.83,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 3
        },
        {
          "id": 6,
          "role": "party_B",
          "text": "I want to be able to relax in my own home without feeling like I am being policed.",
          "emotion": "frustrated",
          "emotion_confidence": 0.82,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 3
        },
        {
          "id": 7,
          "role": "mediator_agent",
          "text": "Both of those needs are completely legitimate. Sleeping well and relaxing at home are basic rights. Interestingly, they do not have to conflict — they just need a shared boundary. What if we discussed a quiet time agreement from 11pm onwards?",
          "emotion": "neutral",
          "emotion_confidence": 0.93,
          "compliance_score": 0.94,
          "practice_active": "needs_compatibility_bridge",
          "ontology_context": ["Mediation:CommonGround", "Norm:MutualRespect", "Mediation:QuietTimeProposal"],
          "agent_action": "propose_boundary_solution",
          "escalation_level": 2
        },
        {
          "id": 8,
          "role": "party_B",
          "text": "11pm is reasonable. I can work with that. I did not realise how much it was affecting them.",
          "emotion": "calm",
          "emotion_confidence": 0.88,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 2
        },
        {
          "id": 9,
          "role": "party_A",
          "text": "Really? That would make such a difference. I would not feel resentful anymore if I knew it would stop at 11.",
          "emotion": "calm",
          "emotion_confidence": 0.90,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 1
        },
        {
          "id": 10,
          "role": "mediator_agent",
          "text": "I can see that this understanding is already making a difference. Would you both be willing to formalise this as a written good-neighbour agreement — nothing legal, just a shared commitment?",
          "emotion": "neutral",
          "emotion_confidence": 0.94,
          "compliance_score": 0.95,
          "practice_active": "formalise_agreement",
          "ontology_context": ["Mediation:WrittenAgreement", "Norm:Commitment", "Norm:GoodNeighbour"],
          "agent_action": "propose_written_commitment",
          "escalation_level": 1
        },
        {
          "id": 11,
          "role": "party_A",
          "text": "Yes. And I am sorry if I came across harshly at any point.",
          "emotion": "calm",
          "emotion_confidence": 0.91,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 1
        },
        {
          "id": 12,
          "role": "party_B",
          "text": "And I am sorry for not being more considerate sooner. Thank you for raising it rather than letting it build further.",
          "emotion": "satisfied",
          "emotion_confidence": 0.92,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "escalation_level": 1
        },
        {
          "id": 13,
          "role": "mediator_agent",
          "text": "What just happened here is exactly what good community looks like. You both came in tense and you are leaving with a plan and an apology exchanged. That is no small thing. I will document the 11pm agreement for your records.",
          "emotion": "satisfied",
          "emotion_confidence": 0.96,
          "compliance_score": 0.97,
          "practice_active": "community_values_affirmation",
          "ontology_context": ["Mediation:PositiveClosure", "Norm:Community", "Norm:Affirmation"],
          "agent_action": "affirm_community_values",
          "escalation_level": 1
        }
      ],
      "dispute_type": "neighbour_noise_complaint",
      "session_outcome": "resolved",
      "avg_compliance": 0.950,
      "avg_emotion_alignment": 0.92,
      "user_trust": 4.6,
      "de_escalation_delta": -3
    }
  ]
}
