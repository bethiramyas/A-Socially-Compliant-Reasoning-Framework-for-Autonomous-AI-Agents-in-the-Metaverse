{
  "dataset_info": {
    "name": "Synthetic E-Commerce Negotiation Interactions",
    "scenario": "ecommerce",
    "description": "Simulated buyer-seller negotiation dialogues between AI agent (as seller) and user avatars (as buyers) in a Unity3D virtual marketplace. Each session is annotated with negotiation outcome, politeness compliance, emotion signals, and ontology-grounded reasoning traces reflecting the framework described in the paper.",
    "num_sessions": 55,
    "num_turns_total": 763,
    "roles": ["seller_agent", "buyer"],
    "emotion_classes": ["neutral", "interested", "skeptical", "frustrated", "satisfied", "amused"],
    "compliance_range": [0.0, 1.0],
    "annotation_schema": {
      "session_id": "Unique session identifier",
      "scenario": "Scenario type",
      "context": "Product, price range, and environment metadata",
      "turns": "List of interaction turns",
      "turn.id": "Turn index within session",
      "turn.role": "Speaker role: seller_agent or buyer",
      "turn.text": "Utterance text",
      "turn.emotion": "Detected or ground-truth emotion label",
      "turn.emotion_confidence": "Confidence score of emotion label [0,1]",
      "turn.compliance_score": "Norm compliance score NC_t in [0,1] (Eq. 9 in paper)",
      "turn.practice_active": "Active social practice from SPT library",
      "turn.ontology_context": "Active ontology concepts guiding agent reasoning",
      "turn.agent_action": "Symbolic action type taken by agent",
      "turn.offer_price": "Current price offer on the table (null if not applicable)",
      "session.outcome": "Session-level outcome: deal_closed / no_deal / partial_agreement",
      "session.final_price": "Agreed price at end of negotiation (null if no deal)",
      "session.avg_compliance": "Mean NC score across session",
      "session.avg_emotion_alignment": "Mean emotion alignment score EA",
      "session.user_trust": "Post-session user trust rating on 5-point scale"
    }
  },
  "sessions": [
    {
      "session_id": "ECM_001",
      "scenario": "ecommerce",
      "context": {
        "product": "Wireless Noise-Cancelling Headphones",
        "listed_price_usd": 120,
        "buyer_budget_usd": 90,
        "environment": "VR Marketplace — Electronics Zone",
        "session_duration_turns": 14
      },
      "turns": [
        {
          "id": 1,
          "role": "seller_agent",
          "text": "Welcome! These headphones feature 30-hour battery life and active noise cancellation. They are listed at 120 dollars. What brings you here today?",
          "emotion": "neutral",
          "emotion_confidence": 0.94,
          "compliance_score": 0.93,
          "practice_active": "product_introduction",
          "ontology_context": ["Product:Headphones", "Feature:NoiseCancellation", "Role:Seller", "Price:120"],
          "agent_action": "introduce_product",
          "offer_price": 120
        },
        {
          "id": 2,
          "role": "buyer",
          "text": "I am looking for good headphones but 120 is above my budget. Is there any flexibility?",
          "emotion": "interested",
          "emotion_confidence": 0.88,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "offer_price": null
        },
        {
          "id": 3,
          "role": "seller_agent",
          "text": "I appreciate you being upfront about that. What range are you comfortable with? I would like to see if we can find something that works for both of us.",
          "emotion": "neutral",
          "emotion_confidence": 0.93,
          "compliance_score": 0.91,
          "practice_active": "polite_counter_inquiry",
          "ontology_context": ["Negotiation:BudgetInquiry", "Norm:Politeness", "Role:Seller"],
          "agent_action": "probe_budget",
          "offer_price": null
        },
        {
          "id": 4,
          "role": "buyer",
          "text": "I was hoping for around 90 dollars.",
          "emotion": "neutral",
          "emotion_confidence": 0.85,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "offer_price": 90
        },
        {
          "id": 5,
          "role": "seller_agent",
          "text": "I understand. At 90, we would be below our cost on this model. However, I can offer you 105 dollars and include a free carrying case valued at 15 dollars — that effectively brings your cost down to 90.",
          "emotion": "neutral",
          "emotion_confidence": 0.92,
          "compliance_score": 0.90,
          "practice_active": "value_bundling",
          "ontology_context": ["Negotiation:CounterOffer", "Norm:FairOffer", "Product:CarryingCase", "Role:Seller"],
          "agent_action": "bundle_counteroffer",
          "offer_price": 105
        },
        {
          "id": 6,
          "role": "buyer",
          "text": "That is a clever offer but I really need the cash price to be lower. Can you do 95?",
          "emotion": "skeptical",
          "emotion_confidence": 0.83,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "offer_price": 95
        },
        {
          "id": 7,
          "role": "seller_agent",
          "text": "I respect that you are being direct. I can come down to 100 and still include the case. That is genuinely the lowest I can go while keeping the product quality guarantee.",
          "emotion": "neutral",
          "emotion_confidence": 0.91,
          "compliance_score": 0.92,
          "practice_active": "firm_but_respectful_concession",
          "ontology_context": ["Negotiation:FinalOffer", "Norm:Honesty", "Norm:Respect", "Role:Seller"],
          "agent_action": "make_final_offer",
          "offer_price": 100
        },
        {
          "id": 8,
          "role": "buyer",
          "text": "Hmm, 100 with the case. What is the warranty like?",
          "emotion": "interested",
          "emotion_confidence": 0.87,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "offer_price": null
        },
        {
          "id": 9,
          "role": "seller_agent",
          "text": "One full year of manufacturer warranty covering any defects. If anything goes wrong, we handle it at no cost to you.",
          "emotion": "neutral",
          "emotion_confidence": 0.93,
          "compliance_score": 0.93,
          "practice_active": "trust_building_disclosure",
          "ontology_context": ["Product:Warranty", "Norm:Transparency", "Role:Seller"],
          "agent_action": "disclose_warranty",
          "offer_price": null
        },
        {
          "id": 10,
          "role": "buyer",
          "text": "Alright, 100 with the case and warranty sounds fair. I will take it.",
          "emotion": "satisfied",
          "emotion_confidence": 0.94,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null,
          "offer_price": 100
        },
        {
          "id": 11,
          "role": "seller_agent",
          "text": "Wonderful! I am glad we found a deal that works. Let me process that for you. You will receive the headphones and case together. Enjoy them!",
          "emotion": "satisfied",
          "emotion_confidence": 0.96,
          "compliance_score": 0.95,
          "practice_active": "deal_closure_and_goodwill",
          "ontology_context": ["Negotiation:DealClosed", "Norm:Courtesy", "Role:Seller"],
          "agent_action": "close_deal",
          "offer_price": 100
        }
      ],
      "session_outcome": "deal_closed",
      "final_price_usd": 100,
      "avg_compliance": 0.923,
      "avg_emotion_alignment": 0.86,
      "user_trust": 4.4
