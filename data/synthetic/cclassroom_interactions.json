    {
      "session_id": "CLS_002",
      "scenario": "classroom",
      "context": {
        "topic": "Introduction to Python Programming",
        "environment": "VR Classroom — SR University",
        "num_students": 1,
        "session_duration_turns": 12
      },
      "turns": [
        {
          "id": 1,
          "role": "teacher_agent",
          "text": "Good to see you today. We are going to write our first Python program. Have you done any programming before?",
          "emotion": "neutral",
          "emotion_confidence": 0.94,
          "compliance_score": 0.93,
          "practice_active": "greeting_and_framing",
          "ontology_context": ["CS:ProgrammingLanguage", "CS:Python", "Role:Tutor", "SessionPhase:Introduction"],
          "agent_action": "open_topic"
        },
        {
          "id": 2,
          "role": "student",
          "text": "No, this is my first time. I am a bit nervous.",
          "emotion": "hesitant",
          "emotion_confidence": 0.87,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        },
        {
          "id": 3,
          "role": "teacher_agent",
          "text": "That is perfectly normal. Everyone starts exactly where you are. Python is one of the friendliest languages to learn. We will go step by step together and you can ask me anything.",
          "emotion": "neutral",
          "emotion_confidence": 0.95,
          "compliance_score": 0.96,
          "practice_active": "anxiety_reduction",
          "ontology_context": ["Pedagogy:Reassurance", "Role:Tutor", "Emotion:Hesitant"],
          "agent_action": "empathise_and_reassure"
        },
        {
          "id": 4,
          "role": "student",
          "text": "Okay thank you. What does print mean?",
          "emotion": "neutral",
          "emotion_confidence": 0.83,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        },
        {
          "id": 5,
          "role": "teacher_agent",
          "text": "Great question. In Python, print is a function that displays text on the screen. If you type print followed by Hello World in quotes, the program will show those words. Would you like to try it?",
          "emotion": "engaged",
          "emotion_confidence": 0.92,
          "compliance_score": 0.94,
          "practice_active": "concept_introduction",
          "ontology_context": ["CS:PrintFunction", "CS:StringLiteral", "Pedagogy:ConcreteExample"],
          "agent_action": "explain_and_invite"
        },
        {
          "id": 6,
          "role": "student",
          "text": "I tried it and it worked! It shows Hello World on the screen.",
          "emotion": "happy",
          "emotion_confidence": 0.95,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        },
        {
          "id": 7,
          "role": "teacher_agent",
          "text": "Congratulations! You just wrote and ran your very first program. That feeling of seeing your code work is something every programmer remembers. Now let us store a value in a variable.",
          "emotion": "happy",
          "emotion_confidence": 0.97,
          "compliance_score": 0.97,
          "practice_active": "celebratory_progression",
          "ontology_context": ["Pedagogy:PositiveReinforcement", "CS:Variable", "Role:Tutor"],
          "agent_action": "celebrate_and_progress"
        },
        {
          "id": 8,
          "role": "student",
          "text": "What is a variable?",
          "emotion": "engaged",
          "emotion_confidence": 0.88,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        },
        {
          "id": 9,
          "role": "teacher_agent",
          "text": "Think of a variable as a labelled box. You can put a value inside it and use the label to retrieve it later. For example, name equals Ramya stores the text Ramya under the label name.",
          "emotion": "engaged",
          "emotion_confidence": 0.93,
          "compliance_score": 0.93,
          "practice_active": "analogy_teaching",
          "ontology_context": ["CS:Variable", "Pedagogy:Analogy", "Role:Tutor"],
          "agent_action": "explain_via_analogy"
        },
        {
          "id": 10,
          "role": "student",
          "text": "Oh so name equals Ramya and then print name would show Ramya?",
          "emotion": "engaged",
          "emotion_confidence": 0.91,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        },
        {
          "id": 11,
          "role": "teacher_agent",
          "text": "Exactly right! You are connecting the concepts beautifully. Try it now and see.",
          "emotion": "happy",
          "emotion_confidence": 0.96,
          "compliance_score": 0.95,
          "practice_active": "positive_reinforcement",
          "ontology_context": ["Pedagogy:PositiveReinforcement", "CS:Variable", "Role:Tutor"],
          "agent_action": "affirm_and_invite_practice"
        },
        {
          "id": 12,
          "role": "student",
          "text": "It works perfectly. This is actually fun!",
          "emotion": "happy",
          "emotion_confidence": 0.97,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        }
      ],
      "session_outcome": "success",
      "avg_compliance": 0.947,
      "avg_emotion_alignment": 0.91,
      "user_trust": 4.7
