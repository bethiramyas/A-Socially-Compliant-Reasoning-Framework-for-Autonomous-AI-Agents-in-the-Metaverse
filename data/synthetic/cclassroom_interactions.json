{
  "dataset_info": {
    "name": "Synthetic Virtual Classroom Interactions",
    "scenario": "classroom",
    "description": "Simulated turn-by-turn dialogue between AI tutor agents and student avatars in a Unity3D virtual classroom environment. Each interaction is annotated with emotion labels, norm compliance scores, and agent reasoning traces.",
    "num_sessions": 60,
    "num_turns_total": 847,
    "roles": ["teacher_agent", "student"],
    "emotion_classes": ["neutral", "confused", "engaged", "frustrated", "happy", "hesitant"],
    "compliance_range": [0.0, 1.0],
    "annotation_schema": {
      "session_id": "Unique session identifier",
      "scenario": "Scenario type",
      "context": "Session topic and environment metadata",
      "turns": "List of interaction turns",
      "turn.id": "Turn index within session",
      "turn.role": "Speaker role: teacher_agent or student",
      "turn.text": "Utterance text",
      "turn.emotion": "Detected or ground-truth emotion label",
      "turn.emotion_confidence": "Confidence score of emotion label [0,1]",
      "turn.compliance_score": "Norm compliance score NC_t in [0,1] (Eq. 9 in paper)",
      "turn.practice_active": "Active social practice from SPT library",
      "turn.ontology_context": "Active ontology concepts guiding agent reasoning",
      "turn.agent_action": "Symbolic action type taken by agent",
      "session.outcome": "Session-level outcome label",
      "session.avg_compliance": "Mean NC score across session",
      "session.avg_emotion_alignment": "Mean emotion alignment score EA across session",
      "session.user_trust": "Post-session user trust rating on 5-point scale"
    }
  },
  "sessions": [
    {
      "session_id": "CLS_001",
      "scenario": "classroom",
      "context": {
        "topic": "Introduction to Quadratic Equations",
        "environment": "VR Classroom — SR University",
        "num_students": 1,
        "session_duration_turns": 14
      },
      "turns": [
        {
          "id": 1,
          "role": "teacher_agent",
          "text": "Welcome! Today we will explore quadratic equations. Let us start with what you already know about linear equations.",
          "emotion": "neutral",
          "emotion_confidence": 0.95,
          "compliance_score": 0.94,
          "practice_active": "greeting_and_framing",
          "ontology_context": ["MathConcept:LinearEquation", "Role:Tutor", "SessionPhase:Introduction"],
          "agent_action": "open_topic"
        },
        {
          "id": 2,
          "role": "student",
          "text": "I know that linear equations have degree one, like y equals 2x plus 3.",
          "emotion": "engaged",
          "emotion_confidence": 0.88,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        },
        {
          "id": 3,
          "role": "teacher_agent",
          "text": "Excellent! That is a perfect foundation. A quadratic equation extends that idea to degree two. Can you guess what ax squared plus bx plus c equals zero might look like on a graph?",
          "emotion": "happy",
          "emotion_confidence": 0.91,
          "compliance_score": 0.96,
          "practice_active": "scaffolded_questioning",
          "ontology_context": ["MathConcept:QuadraticEquation", "Pedagogy:Scaffolding", "Role:Tutor"],
          "agent_action": "prompt_prior_knowledge"
        },
        {
          "id": 4,
          "role": "student",
          "text": "Maybe a curve? I am not sure.",
          "emotion": "hesitant",
          "emotion_confidence": 0.82,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        },
        {
          "id": 5,
          "role": "teacher_agent",
          "text": "That is right — it forms a parabola, which is a U-shaped curve. It is completely fine to be unsure at first. Let us look at a visual example together.",
          "emotion": "neutral",
          "emotion_confidence": 0.93,
          "compliance_score": 0.95,
          "practice_active": "empathetic_encouragement",
          "ontology_context": ["MathConcept:Parabola", "Pedagogy:Reassurance", "Role:Tutor"],
          "agent_action": "affirm_and_redirect"
        },
        {
          "id": 6,
          "role": "student",
          "text": "Oh I see it now on the board. So both sides go upward?",
          "emotion": "engaged",
          "emotion_confidence": 0.90,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        },
        {
          "id": 7,
          "role": "teacher_agent",
          "text": "Exactly! When the coefficient a is positive, the parabola opens upward. When a is negative, it opens downward. Which case do you think applies to x squared minus 4 equals zero?",
          "emotion": "engaged",
          "emotion_confidence": 0.94,
          "compliance_score": 0.93,
          "practice_active": "guided_discovery",
          "ontology_context": ["MathConcept:ParabolaDirection", "MathConcept:Coefficient", "Pedagogy:SocraticMethod"],
          "agent_action": "pose_example_question"
        },
        {
          "id": 8,
          "role": "student",
          "text": "The coefficient of x squared is 1 which is positive so it opens upward.",
          "emotion": "engaged",
          "emotion_confidence": 0.92,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        },
        {
          "id": 9,
          "role": "teacher_agent",
          "text": "Perfect reasoning! You identified the coefficient correctly and applied the rule precisely. Now can you find the values of x that satisfy the equation?",
          "emotion": "happy",
          "emotion_confidence": 0.96,
          "compliance_score": 0.97,
          "practice_active": "positive_reinforcement",
          "ontology_context": ["Pedagogy:PositiveReinforcement", "MathConcept:Roots", "Role:Tutor"],
          "agent_action": "praise_and_extend"
        },
        {
          "id": 10,
          "role": "student",
          "text": "So x squared equals 4, meaning x is 2 or x is negative 2?",
          "emotion": "engaged",
          "emotion_confidence": 0.91,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        },
        {
          "id": 11,
          "role": "teacher_agent",
          "text": "That is exactly right. Both plus 2 and minus 2 are roots. You have just solved your first quadratic equation. Shall we try a slightly harder one together?",
          "emotion": "happy",
          "emotion_confidence": 0.97,
          "compliance_score": 0.95,
          "practice_active": "celebratory_progression",
          "ontology_context": ["MathConcept:Roots", "Pedagogy:Progression", "Role:Tutor"],
          "agent_action": "celebrate_and_progress"
        },
        {
          "id": 12,
          "role": "student",
          "text": "Yes please, I am feeling more confident now.",
          "emotion": "happy",
          "emotion_confidence": 0.94,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        },
        {
          "id": 13,
          "role": "teacher_agent",
          "text": "Wonderful. Let us try x squared plus 5x plus 6 equals zero. Take your time, there is no rush.",
          "emotion": "neutral",
          "emotion_confidence": 0.93,
          "compliance_score": 0.92,
          "practice_active": "paced_challenge",
          "ontology_context": ["MathConcept:Factoring", "Pedagogy:PacedLearning", "Role:Tutor"],
          "agent_action": "pose_challenge"
        },
        {
          "id": 14,
          "role": "student",
          "text": "I think I can factor it as x plus 2 times x plus 3, so x is negative 2 or negative 3.",
          "emotion": "engaged",
          "emotion_confidence": 0.90,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        }
      ],
      "session_outcome": "success",
      "avg_compliance": 0.945,
      "avg_emotion_alignment": 0.88,
      "user_trust": 4.6
