    {
      "session_id": "CLS_003",
      "scenario": "classroom",
      "context": {
        "topic": "Critical Thinking and Argumentation",
        "environment": "VR Classroom — SR University",
        "num_students": 1,
        "session_duration_turns": 10
      },
      "turns": [
        {
          "id": 1,
          "role": "teacher_agent",
          "text": "Today we will practise building strong arguments. A good argument has a clear claim, supporting evidence, and logical reasoning. Does that structure sound familiar?",
          "emotion": "neutral",
          "emotion_confidence": 0.93,
          "compliance_score": 0.92,
          "practice_active": "concept_framing",
          "ontology_context": ["CriticalThinking:Argument", "CriticalThinking:Claim", "Role:Tutor"],
          "agent_action": "open_topic"
        },
        {
          "id": 2,
          "role": "student",
          "text": "I have heard of it but I always struggle with the evidence part.",
          "emotion": "frustrated",
          "emotion_confidence": 0.84,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        },
        {
          "id": 3,
          "role": "teacher_agent",
          "text": "That is one of the most common challenges, and it is great that you can identify it. Let us work through it together. Can you give me a claim about any topic you care about?",
          "emotion": "neutral",
          "emotion_confidence": 0.92,
          "compliance_score": 0.94,
          "practice_active": "normalise_and_redirect",
          "ontology_context": ["Pedagogy:Normalisation", "CriticalThinking:Claim", "Emotion:Frustrated"],
          "agent_action": "empathise_and_scaffold"
        },
        {
          "id": 4,
          "role": "student",
          "text": "Social media is harmful to teenagers.",
          "emotion": "neutral",
          "emotion_confidence": 0.85,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        },
        {
          "id": 5,
          "role": "teacher_agent",
          "text": "That is a strong and relevant claim. Now what evidence would you offer to support it? Think about studies, statistics, or real examples you have seen.",
          "emotion": "engaged",
          "emotion_confidence": 0.91,
          "compliance_score": 0.93,
          "practice_active": "guided_evidence_building",
          "ontology_context": ["CriticalThinking:Evidence", "CriticalThinking:Statistics", "Pedagogy:Scaffolding"],
          "agent_action": "prompt_evidence"
        },
        {
          "id": 6,
          "role": "student",
          "text": "Studies show increased anxiety and depression rates linked to heavy social media use.",
          "emotion": "engaged",
          "emotion_confidence": 0.89,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        },
        {
          "id": 7,
          "role": "teacher_agent",
          "text": "Excellent. That is a research-based evidence point. Now the final piece — what is the logical link between that evidence and your claim? Why does increased anxiety prove harm?",
          "emotion": "engaged",
          "emotion_confidence": 0.93,
          "compliance_score": 0.92,
          "practice_active": "logical_connection_prompting",
          "ontology_context": ["CriticalThinking:Reasoning", "CriticalThinking:Causality", "Pedagogy:SocraticMethod"],
          "agent_action": "prompt_reasoning"
        },
        {
          "id": 8,
          "role": "student",
          "text": "Because psychological harm like anxiety negatively impacts wellbeing which is harm by definition.",
          "emotion": "engaged",
          "emotion_confidence": 0.90,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        },
        {
          "id": 9,
          "role": "teacher_agent",
          "text": "That is a logically sound connection. You have just constructed a complete argument with a claim, evidence, and reasoning. You solved the evidence problem you mentioned at the start.",
          "emotion": "happy",
          "emotion_confidence": 0.96,
          "compliance_score": 0.96,
          "practice_active": "reflective_celebration",
          "ontology_context": ["Pedagogy:MetacognitiveReflection", "CriticalThinking:Argument", "Role:Tutor"],
          "agent_action": "reflect_and_celebrate"
        },
        {
          "id": 10,
          "role": "student",
          "text": "I did not even realise I was doing it. That actually helped a lot.",
          "emotion": "happy",
          "emotion_confidence": 0.95,
          "compliance_score": null,
          "practice_active": null,
          "ontology_context": null,
          "agent_action": null
        }
      ],
